<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>KOSKU — Cari Kos Terbaik Sesuai Kebutuhanmu</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,800&family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --sand: #e1b382;
        --sand-dark: #c89666;
        --night: #2d545e;
        --night-dark: #12343b;
        --cream: #faf3ea;
        --cream-2: #f3e6d3;
        --white: #fffdfb;
        --text: #2a2420;
        --text-soft: #6f6053;
        --line: #e7d9c6;
        --ok: #3f7d5c;
        --ok-bg: #e4efe6;
        --warn: #a8722f;
        --warn-bg: #faead2;
        --danger: #b1503f;
        --danger-bg: #f7e6e0;
        --radius: 14px;
        --shadow: 0 4px 18px rgba(18, 52, 59, 0.08);
        --shadow-lg: 0 18px 40px rgba(18, 52, 59, 0.16);
      }
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        font-family: "Inter", sans-serif;
        background: var(--cream);
        color: var(--text);
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
      }
      h1,
      h2,
      h3,
      h4 {
        font-family: "Fraunces", serif;
        color: var(--night-dark);
        font-weight: 600;
        letter-spacing: -0.01em;
      }
      a {
        color: inherit;
        text-decoration: none;
      }
      button {
        font-family: "Inter", sans-serif;
        cursor: pointer;
        border: none;
      }
      img {
        max-width: 100%;
        display: block;
      }
      input,
      select,
      textarea {
        font-family: "Inter", sans-serif;
      }
      ::selection {
        background: var(--sand);
        color: var(--night-dark);
      }

      /* ---------- Roof / signature motif ---------- */
      .roof-tag {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 6px;
      }
      .roof-mark {
        width: 20px;
        height: 16px;
        position: relative;
        flex: none;
      }
      .roof-mark svg {
        width: 100%;
        height: 100%;
        display: block;
      }

      .roof-divider {
        height: 10px;
        width: 100%;
        background:
          linear-gradient(135deg, transparent 49%, var(--cream) 50%) 0 0/16px
            16px repeat-x,
          linear-gradient(-135deg, transparent 49%, var(--cream) 50%) 0 0/16px
            16px repeat-x;
        background-color: var(--night-dark);
      }

      /* ---------- Buttons ---------- */
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 11px 20px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 14.5px;
        transition: all 0.18s ease;
        white-space: nowrap;
      }
      .btn-primary {
        background: var(--night);
        color: var(--white);
      }
      .btn-primary:hover {
        background: var(--night-dark);
        transform: translateY(-1px);
      }
      .btn-sand {
        background: var(--sand);
        color: var(--night-dark);
      }
      .btn-sand:hover {
        background: var(--sand-dark);
      }
      .btn-outline {
        background: transparent;
        color: var(--night);
        border: 1.5px solid var(--night);
      }
      .btn-outline:hover {
        background: var(--night);
        color: var(--white);
      }
      .btn-ghost {
        background: transparent;
        color: var(--text-soft);
      }
      .btn-ghost:hover {
        color: var(--night-dark);
      }
      .btn-sm {
        padding: 7px 13px;
        font-size: 13px;
        border-radius: 8px;
      }
      .btn-block {
        width: 100%;
      }
      .btn-danger-outline {
        background: transparent;
        border: 1.5px solid var(--danger);
        color: var(--danger);
      }
      .btn-danger-outline:hover {
        background: var(--danger);
        color: #fff;
      }

      /* ---------- Topbar ---------- */
      #topbar {
        position: sticky;
        top: 0;
        z-index: 200;
        background: var(--white);
        border-bottom: 1px solid var(--line);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 32px;
        gap: 20px;
      }
      .logo {
        display: flex;
        align-items: center;
        gap: 9px;
        font-family: "Fraunces", serif;
        font-weight: 800;
        font-size: 22px;
        color: var(--night-dark);
        cursor: pointer;
      }
      .logo .roof-mark {
        width: 26px;
        height: 22px;
      }
      #topbar nav {
        display: flex;
        gap: 6px;
        align-items: center;
      }
      #topbar nav a.navlink {
        padding: 9px 14px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 14.5px;
        color: var(--text-soft);
        transition: all 0.15s ease;
      }
      #topbar nav a.navlink:hover {
        background: var(--cream-2);
        color: var(--night-dark);
      }
      #topbar nav a.navlink.active {
        color: var(--night-dark);
        background: var(--cream-2);
      }
      .topbar-actions {
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .user-chip {
        display: flex;
        align-items: center;
        gap: 9px;
        padding: 6px 12px 6px 6px;
        border-radius: 30px;
        background: var(--cream-2);
        cursor: pointer;
        border: 1px solid var(--line);
      }
      .avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--sand), var(--sand-dark));
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--night-dark);
        font-weight: 700;
        font-size: 13px;
      }
      .avatar.lg {
        width: 64px;
        height: 64px;
        font-size: 22px;
      }

      /* ---------- Shell w/ sidebar ---------- */
      #shell {
        display: flex;
        min-height: calc(100vh - 64px);
      }
      #sidebar {
        width: 236px;
        flex: none;
        background: var(--night-dark);
        color: #eadfcf;
        padding: 22px 14px;
        display: flex;
        flex-direction: column;
        gap: 2px;
      }
      #sidebar .side-title {
        color: #a9bfc3;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.09em;
        padding: 10px 12px 6px;
        font-weight: 700;
      }
      .side-link {
        display: flex;
        align-items: center;
        gap: 11px;
        padding: 10px 12px;
        border-radius: 9px;
        font-weight: 600;
        font-size: 14.5px;
        color: #d9e2e2;
        transition: all 0.15s ease;
      }
      .side-link svg {
        width: 18px;
        height: 18px;
        flex: none;
        opacity: 0.85;
      }
      .side-link:hover {
        background: rgba(225, 179, 130, 0.12);
        color: #fff;
      }
      .side-link.active {
        background: var(--sand);
        color: var(--night-dark);
      }
      .side-link.active svg {
        opacity: 1;
      }
      .side-link.logout {
        margin-top: auto;
      }
      #main {
        flex: 1;
        padding: 30px 34px;
        max-width: 100%;
        overflow-x: hidden;
      }
      .page-shell-guest #sidebar {
        display: none;
      }

      /* ---------- Generic layout helpers ---------- */
      .page {
        display: none;
        animation: fadeIn 0.25s ease;
      }
      .page.active {
        display: block;
      }
      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateY(6px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .container {
        max-width: 1180px;
        margin: 0 auto;
        padding: 0 32px;
      }
      .section-head {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-bottom: 20px;
        gap: 16px;
        flex-wrap: wrap;
      }
      .section-head h2 {
        font-size: 24px;
      }
      .eyebrow {
        display: inline-block;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--sand-dark);
        margin-bottom: 8px;
      }
      .card {
        background: var(--white);
        border-radius: var(--radius);
        border: 1px solid var(--line);
        box-shadow: var(--shadow);
      }
      .grid {
        display: grid;
        gap: 20px;
      }
      .grid-3 {
        grid-template-columns: repeat(3, 1fr);
      }
      .grid-2 {
        grid-template-columns: repeat(2, 1fr);
      }
      @media (max-width: 1000px) {
        .grid-3 {
          grid-template-columns: repeat(2, 1fr);
        }
      }
      @media (max-width: 680px) {
        .grid-3,
        .grid-2 {
          grid-template-columns: 1fr;
        }
      }

      /* ---------- Hero ---------- */
      .hero {
        background: linear-gradient(
          120deg,
          var(--night-dark) 0%,
          var(--night) 65%
        );
        border-radius: 22px;
        padding: 52px 44px;
        color: #fff;
        display: grid;
        grid-template-columns: 1.15fr 1fr;
        gap: 36px;
        align-items: center;
        overflow: hidden;
        position: relative;
        margin: 26px 0 40px;
      }
      .hero:before {
        content: "";
        position: absolute;
        right: -60px;
        top: -60px;
        width: 280px;
        height: 280px;
        background: radial-gradient(circle, var(--sand) 0%, transparent 70%);
        opacity: 0.25;
      }
      .hero h1 {
        color: #fff;
        font-size: 41px;
        line-height: 1.12;
        margin-bottom: 14px;
        max-width: 520px;
      }
      .hero p {
        color: #cfe0e0;
        font-size: 15.5px;
        line-height: 1.6;
        max-width: 480px;
        margin-bottom: 24px;
      }
      .search-bar {
        display: flex;
        background: #fff;
        border-radius: 12px;
        padding: 6px;
        gap: 6px;
        max-width: 520px;
        box-shadow: var(--shadow-lg);
      }
      .search-bar input {
        flex: 1;
        border: none;
        padding: 11px 14px;
        font-size: 14.5px;
        border-radius: 8px;
        outline: none;
        color: var(--text);
      }
      .hero-illustration {
        height: 230px;
        border-radius: 16px;
        background: linear-gradient(
          160deg,
          var(--sand) 0%,
          var(--sand-dark) 100%
        );
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: flex-end;
        justify-content: center;
      }
      .hero-illustration svg {
        width: 78%;
      }

      /* ---------- Kos card ---------- */
      .kos-card {
        background: var(--white);
        border-radius: var(--radius);
        overflow: hidden;
        border: 1px solid var(--line);
        box-shadow: var(--shadow);
        transition:
          transform 0.18s ease,
          box-shadow 0.18s ease;
        position: relative;
      }
      .kos-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-lg);
      }
      .kos-photo {
        height: 150px;
        position: relative;
        background: linear-gradient(150deg, var(--sand-dark), var(--sand));
        display: flex;
        align-items: flex-end;
        justify-content: center;
        overflow: hidden;
      }
      .kos-photo svg {
        width: 64%;
        opacity: 0.92;
      }
      .kos-photo .status-badge {
        position: absolute;
        top: 10px;
        left: 10px;
        font-size: 11px;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 20px;
      }
      .status-badge.tersedia {
        background: var(--ok-bg);
        color: var(--ok);
      }
      .status-badge.penuh {
        background: var(--danger-bg);
        color: var(--danger);
      }
      .fav-btn {
        position: absolute;
        top: 10px;
        right: 10px;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.92);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.15s ease;
      }
      .fav-btn svg {
        width: 16px;
        height: 16px;
        stroke: var(--night-dark);
        fill: none;
        transition: all 0.15s;
      }
      .fav-btn.active svg {
        fill: var(--danger);
        stroke: var(--danger);
      }
      .kos-body {
        padding: 15px 16px 17px;
      }
      .kos-body .kname {
        font-family: "Fraunces", serif;
        font-weight: 600;
        font-size: 16.5px;
        color: var(--night-dark);
        margin-bottom: 3px;
      }
      .kos-body .kaddr {
        font-size: 12.5px;
        color: var(--text-soft);
        margin-bottom: 9px;
        display: flex;
        gap: 5px;
        align-items: flex-start;
      }
      .kos-body .kaddr svg {
        width: 13px;
        height: 13px;
        flex: none;
        margin-top: 1px;
        opacity: 0.7;
      }
      .kprice {
        font-weight: 800;
        color: var(--night);
        font-size: 16px;
        margin-bottom: 8px;
      }
      .kprice span {
        font-weight: 500;
        font-size: 12px;
        color: var(--text-soft);
      }
      .krating {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 12.5px;
        color: var(--text-soft);
        margin-bottom: 10px;
        font-weight: 600;
      }
      .krating svg {
        width: 13px;
        height: 13px;
        fill: var(--sand-dark);
        stroke: none;
      }
      .kfacilities {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
      }
      .fac-tag {
        font-size: 10.5px;
        font-weight: 600;
        color: var(--night);
        background: var(--cream-2);
        padding: 3px 8px;
        border-radius: 6px;
      }

      /* ---------- Forms ---------- */
      .field {
        margin-bottom: 16px;
      }
      .field label {
        display: block;
        font-size: 13.5px;
        font-weight: 600;
        color: var(--night-dark);
        margin-bottom: 7px;
      }
      .field input,
      .field select,
      .field textarea {
        width: 100%;
        padding: 11px 13px;
        border: 1.5px solid var(--line);
        border-radius: 9px;
        font-size: 14px;
        outline: none;
        transition: border-color 0.15s ease;
        background: var(--white);
        color: var(--text);
      }
      .field input:focus,
      .field select:focus,
      .field textarea:focus {
        border-color: var(--night);
      }
      .pw-wrap {
        position: relative;
      }
      .pw-wrap svg {
        position: absolute;
        right: 13px;
        top: 50%;
        transform: translateY(-50%);
        width: 17px;
        height: 17px;
        opacity: 0.55;
        cursor: pointer;
      }

      .auth-wrap {
        max-width: 440px;
        margin: 46px auto;
        padding: 0 20px;
      }
      .auth-card {
        padding: 34px 32px;
      }
      .auth-card h2 {
        text-align: center;
        font-size: 23px;
        margin-bottom: 4px;
      }
      .auth-sub {
        text-align: center;
        color: var(--text-soft);
        font-size: 13.5px;
        margin-bottom: 24px;
      }
      .role-toggle {
        display: flex;
        gap: 10px;
        margin-bottom: 22px;
      }
      .role-opt {
        flex: 1;
        border: 1.5px solid var(--line);
        border-radius: 10px;
        padding: 13px 10px;
        text-align: center;
        font-size: 13px;
        font-weight: 700;
        color: var(--text-soft);
        transition: all 0.15s ease;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
      }
      .role-opt svg {
        width: 20px;
        height: 20px;
      }
      .role-opt.active {
        border-color: var(--night);
        background: var(--cream-2);
        color: var(--night-dark);
      }
      .divider-or {
        display: flex;
        align-items: center;
        gap: 12px;
        color: var(--text-soft);
        font-size: 12.5px;
        margin: 18px 0;
      }
      .divider-or:before,
      .divider-or:after {
        content: "";
        flex: 1;
        height: 1px;
        background: var(--line);
      }
      .social-row {
        display: flex;
        gap: 10px;
      }
      .social-btn {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 10px;
        border: 1.5px solid var(--line);
        border-radius: 9px;
        font-weight: 600;
        font-size: 13.5px;
        color: var(--text);
      }
      .social-btn:hover {
        border-color: var(--sand-dark);
        background: var(--cream);
      }
      .auth-foot {
        text-align: center;
        font-size: 13.5px;
        color: var(--text-soft);
        margin-top: 18px;
      }
      .auth-foot b {
        color: var(--night);
        cursor: pointer;
      }

      /* ---------- Filter panel / search page ---------- */
      .search-layout {
        display: grid;
        grid-template-columns: 260px 1fr;
        gap: 26px;
        align-items: flex-start;
      }
      .filter-panel {
        padding: 20px;
      }
      .filter-panel h3 {
        font-size: 16px;
        margin-bottom: 16px;
      }
      .filter-group {
        margin-bottom: 18px;
      }
      .filter-group > label {
        display: block;
        font-size: 12.5px;
        font-weight: 700;
        color: var(--night-dark);
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-bottom: 9px;
      }
      .range-row {
        display: flex;
        gap: 8px;
        align-items: center;
      }
      .range-row input {
        width: 100%;
      }
      .chk-row {
        display: flex;
        align-items: center;
        gap: 9px;
        font-size: 13.5px;
        padding: 5px 0;
        color: var(--text);
      }
      .chk-row input {
        accent-color: var(--night);
        width: 16px;
        height: 16px;
      }
      .result-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
        flex-wrap: wrap;
        gap: 10px;
      }
      .result-search {
        display: flex;
        align-items: center;
        gap: 8px;
        background: var(--white);
        border: 1.5px solid var(--line);
        border-radius: 10px;
        padding: 9px 14px;
        flex: 1;
        max-width: 420px;
      }
      .result-search input {
        border: none;
        outline: none;
        flex: 1;
        font-size: 13.5px;
      }
      .result-search svg {
        width: 16px;
        height: 16px;
        opacity: 0.55;
      }

      /* ---------- Detail page ---------- */
      .detail-layout {
        display: grid;
        grid-template-columns: 1.6fr 1fr;
        gap: 28px;
        align-items: flex-start;
      }
      .detail-hero-photo {
        height: 300px;
        border-radius: 16px;
        background: linear-gradient(150deg, var(--sand-dark), var(--sand));
        position: relative;
        display: flex;
        align-items: flex-end;
        justify-content: center;
        overflow: hidden;
        margin-bottom: 14px;
      }
      .detail-hero-photo svg {
        width: 46%;
      }
      .thumb-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 10px;
      }
      .thumb {
        height: 64px;
        border-radius: 9px;
        background: linear-gradient(150deg, var(--cream-2), var(--sand));
      }
      .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px 28px;
        margin: 18px 0;
      }
      .info-item {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 13.5px;
      }
      .info-item svg {
        width: 17px;
        height: 17px;
        color: var(--night);
        flex: none;
      }
      .info-item b {
        color: var(--night-dark);
      }
      .review-item {
        display: flex;
        gap: 12px;
        padding: 16px 0;
        border-top: 1px solid var(--line);
      }
      .review-item:first-child {
        border-top: none;
      }
      .stars-row {
        display: flex;
        gap: 2px;
      }
      .stars-row svg {
        width: 13px;
        height: 13px;
        fill: var(--sand-dark);
      }
      .stars-row svg.empty {
        fill: var(--line);
      }
      .map-box {
        height: 150px;
        border-radius: 12px;
        margin-top: 14px;
        position: relative;
        overflow: hidden;
        background:
          repeating-linear-gradient(
            0deg,
            var(--cream-2),
            var(--cream-2) 1px,
            var(--white) 1px,
            var(--white) 26px
          ),
          repeating-linear-gradient(
            90deg,
            var(--cream-2),
            var(--cream-2) 1px,
            transparent 1px,
            transparent 26px
          );
      }
      .map-pin {
        position: absolute;
        left: 44%;
        top: 38%;
        width: 26px;
        height: 26px;
        color: var(--danger);
      }
      .sticky-book {
        position: sticky;
        top: 84px;
      }

      /* ---------- Table ---------- */
      table.data-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13.5px;
      }
      table.data-table th {
        text-align: left;
        padding: 12px 14px;
        background: var(--cream-2);
        color: var(--night-dark);
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        font-weight: 700;
      }
      table.data-table td {
        padding: 12px 14px;
        border-bottom: 1px solid var(--line);
        vertical-align: middle;
      }
      table.data-table tr:last-child td {
        border-bottom: none;
      }
      .thumb-sm {
        width: 46px;
        height: 36px;
        border-radius: 7px;
        background: linear-gradient(150deg, var(--sand-dark), var(--sand));
        flex: none;
      }
      .row-flex {
        display: flex;
        align-items: center;
        gap: 10px;
      }

      /* ---------- Tabs ---------- */
      .tab-row {
        display: flex;
        gap: 4px;
        background: var(--cream-2);
        padding: 4px;
        border-radius: 10px;
        width: fit-content;
        margin-bottom: 18px;
      }
      .tab-item {
        padding: 8px 18px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 13.5px;
        color: var(--text-soft);
      }
      .tab-item.active {
        background: var(--white);
        color: var(--night-dark);
        box-shadow: var(--shadow);
      }

      /* ---------- Stat cards ---------- */
      .stat-card {
        padding: 18px 20px;
        display: flex;
        align-items: center;
        gap: 14px;
      }
      .stat-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        background: var(--cream-2);
        display: flex;
        align-items: center;
        justify-content: center;
        flex: none;
      }
      .stat-icon svg {
        width: 21px;
        height: 21px;
        color: var(--night);
      }
      .stat-num {
        font-family: "Fraunces", serif;
        font-size: 25px;
        font-weight: 700;
        color: var(--night-dark);
      }
      .stat-label {
        font-size: 12px;
        color: var(--text-soft);
        font-weight: 600;
      }

      /* ---------- Booking / notif items ---------- */
      .booking-item {
        display: flex;
        gap: 14px;
        padding: 16px;
        align-items: center;
      }
      .booking-item + .booking-item {
        border-top: 1px solid var(--line);
      }
      .badge {
        font-size: 11px;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 20px;
      }
      .badge.menunggu {
        background: var(--warn-bg);
        color: var(--warn);
      }
      .badge.disetujui,
      .badge.ditolak-x {
        background: var(--ok-bg);
        color: var(--ok);
      }
      .badge.ditolak {
        background: var(--danger-bg);
        color: var(--danger);
      }
      .badge.selesai {
        background: var(--cream-2);
        color: var(--night-dark);
      }
      .notif-item {
        display: flex;
        gap: 12px;
        padding: 14px 16px;
        align-items: flex-start;
      }
      .notif-item + .notif-item {
        border-top: 1px solid var(--line);
      }
      .notif-dot {
        width: 9px;
        height: 9px;
        border-radius: 50%;
        background: var(--sand-dark);
        flex: none;
        margin-top: 6px;
      }
      .notif-item.read .notif-dot {
        background: var(--line);
      }
      .notif-item.read {
        opacity: 0.65;
      }

      /* ---------- chart mock ---------- */
      .mini-chart {
        height: 130px;
        display: flex;
        align-items: flex-end;
        gap: 8px;
        padding-top: 10px;
      }
      .mini-chart .bar {
        flex: 1;
        background: linear-gradient(180deg, var(--sand), var(--sand-dark));
        border-radius: 6px 6px 0 0;
      }

      .toast-wrap {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 999;
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      .toast {
        background: var(--night-dark);
        color: #fff;
        padding: 13px 20px;
        border-radius: 10px;
        font-size: 13.5px;
        font-weight: 600;
        box-shadow: var(--shadow-lg);
        display: flex;
        align-items: center;
        gap: 10px;
        animation: toastIn 0.25s ease;
      }
      .toast svg {
        width: 16px;
        height: 16px;
        color: var(--sand);
      }
      @keyframes toastIn {
        from {
          opacity: 0;
          transform: translateX(20px);
        }
        to {
          opacity: 1;
          transform: translateX(0);
        }
      }

      .pill-link {
        font-size: 13.5px;
        font-weight: 700;
        color: var(--night);
      }
      .pill-link:hover {
        text-decoration: underline;
      }
      .helper-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 12.5px;
        margin-top: -8px;
        margin-bottom: 16px;
      }

      @media (max-width: 900px) {
        #sidebar {
          display: none;
        }
        .hero {
          grid-template-columns: 1fr;
        }
        .detail-layout,
        .search-layout {
          grid-template-columns: 1fr;
        }
        #topbar nav {
          display: none;
        }
      }
    </style>
